    <!-- Debug preferences -->
    <string name="pref_open_log_dir_name">Logmap openen</string>
    <string name="pref_open_log_dir_desc">Open de logmap in de systeembestandsbeheerder (DocumentsUI).</string>
    <string name="pref_allow_reinstall_name">Herinstallatie toestaan</string>
    <string name="pref_allow_reinstall_desc">Als de nieuwste OTA overeenkomt met de huidige OS-vingerafdruk, beschouw deze dan als een update. Dit kan leiden tot voortdurende herinstallaties als automatische updates zijn ingeschakeld.</string>
    <string name="pref_revert_completed_name">Voltooide update terugdraaien</string>
    <string name="pref_revert_completed_desc">Dit is alleen mogelijk nadat een update is voltooid, maar vóór het opnieuw opstarten. Dit is uitsluitend bedoeld voor foutopsporingsdoeleinden.</string>
    <string name="pref_install_csig_cert_name">csig-certificaat installeren</string>
    <string name="pref_install_csig_cert_desc">Het certificaat wordt alleen gebruikt om <tt>.csig</tt>-bestanden te verifiëren. Dit is niet nodig wanneer het certificaat al aanwezig is in de <tt>otacerts.zip</tt> van het systeem. Houd het certificaat ingedrukt om het te verwijderen.</string>
    <string name="pref_pin_network_id_name">Vastzetten op specifiek netwerk-ID</string>
    <string name="pref_pin_network_id_desc">Dit garandeert dat verkeer niet lekt naar een onverwacht (bijv. gemeten) netwerk. Wanneer dit is uitgeschakeld, heeft de optie voor een onmetered netwerk geen effect als het netwerk tijdens het downloaden verandert. Het uitschakelen hiervan is nodig bij gebruik van WireGuard\'s kernel-modus, omdat die de Android\'s netwerk‑API\'s breekt.</string>

